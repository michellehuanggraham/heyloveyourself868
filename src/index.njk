/* ── 計算主命數 ── */
function reduce(n) {
  while (n > 9) {
    let s = 0, t = n;
    while (t > 0) { s += t % 10; t = Math.floor(t / 10); }
    n = s;
  }
  return n;
}
function lifeNum(y, m, d) {
  let sum = 0;
  for (const ch of String(y) + String(m) + String(d)) sum += +ch;
  return reduce(sum);
}

/* ── 解碼 ── */
function decode() {
  const sy = document.getElementById('sy').value;
  const sm = document.getElementById('sm').value;
  const sd = document.getElementById('sd').value;
  const ly = document.getElementById('ly').value;
  const lm = document.getElementById('lm').value;
  const ld = document.getElementById('ld').value;

  const hasSolar = sy && sm && sd;
  const hasLunar = ly && lm && ld;

  if (!hasSolar && !hasLunar) {
    alert('請至少填寫一種曆法的完整出生年月日！');
    return;
  }

  const area = document.getElementById('resultArea');
  const sCard = document.getElementById('solarCard');
  const lCard = document.getElementById('lunarCard');

  if (hasSolar) {
    const n = lifeNum(+sy, +sm, +sd);
    document.getElementById('sNum').textContent = n;
    document.getElementById('sDesc').textContent = SOLAR[n];
    sCard.style.display = 'block';
  } else {
    sCard.style.display = 'none';
  }

  if (hasLunar) {
    const n = lifeNum(+ly, +lm, +ld);
    document.getElementById('lNum').textContent = n;
    document.getElementById('lDesc').textContent = LUNAR[n];
    lCard.style.display = 'block';
  } else {
    lCard.style.display = 'none';
  }

  area.classList.remove('show');
  requestAnimationFrame(() => {
    area.classList.add('show');
    area.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
}
</script>

